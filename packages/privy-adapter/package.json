{
  "name": "@pollar/privy-adapter",
  "version": "0.10.0-rc.8",
  "description": "Privy client-side wallet adapter for @pollar/core — sign Stellar transactions with a user's Privy embedded Stellar wallet via raw-hash signing.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit && eslint src",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@pollar/core": "^0.10.0-rc.0",
    "@stellar/stellar-sdk": "^15.1.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "@privy-io/react-auth": "^3",
    "@privy-io/expo": ">=0.69 <1",
    "react-native-webview": ">=13"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "@privy-io/react-auth": {
      "optional": true
    },
    "@privy-io/expo": {
      "optional": true
    },
    "react-native-webview": {
      "optional": true
    }
  },
  "dependencies": {
    "@pollar/core": "^0.10.0-rc.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@privy-io/react-auth": "^3.32.2",
    "@stellar/stellar-sdk": "^15.1.0",
    "eslint": "^10.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
