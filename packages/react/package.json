{
  "name": "@pollar/react",
  "version": "0.10.1-rc.1",
  "description": "React components for Pollar authentication",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit && eslint src",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@pollar/core": "^0.10.1-rc.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@pollar/core": "^0.10.1-rc.0",
    "@simplewebauthn/browser": "^13.3.0",
    "qr.js": "^0.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
