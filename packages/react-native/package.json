{
    "name": "@pollar/react-native",
    "version": "0.5.3",
    "description": "React Native components for Pollar authentication",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "peerDependencies": {
        "@pollar/core": "*",
        "react": ">=18",
        "react-native": "*"
    },
    "dependencies": {
        "@pollar/core": "*"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "@types/react": "^18.0.0",
        "react": "^18.0.0",
        "react-native": "^0.72.0",
        "tsup": "^8.3.0",
        "typescript": "^5.7.0"
    }
}
