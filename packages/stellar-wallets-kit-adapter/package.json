{
  "name": "@pollar/stellar-wallets-kit-adapter",
  "version": "0.11.0",
  "description": "Stellar Wallets Kit adapter for @pollar/core — plug additional wallet modules (xBull, Lobstr, WalletConnect, hardware wallets…) into Pollar without bundling them into @pollar/core.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit && eslint src",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@creit.tech/stellar-wallets-kit": "^2.0.0",
    "@pollar/core": "^0.11.0"
  },
  "dependencies": {
    "@pollar/core": "^0.11.0"
  },
  "devDependencies": {
    "@creit.tech/stellar-wallets-kit": "^2.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.61.0"
  }
}
