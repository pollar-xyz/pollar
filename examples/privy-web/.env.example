# Copy to .env.local and fill in. All VITE_* vars are exposed to the browser.

# Privy app id (public, from the Privy dashboard). NOT a secret.
VITE_PRIVY_APP_ID=

# Your Pollar SDK API key.
VITE_POLLAR_API_KEY=

# Optional: override the Pollar SDK base URL (default https://sdk.api.pollar.xyz).
# VITE_POLLAR_BASE_URL=

# Optional: 'testnet' (default) or 'mainnet'. Match your Privy app's Stellar network.
# VITE_STELLAR_NETWORK=testnet
