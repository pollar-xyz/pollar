# Copy to .env.local and fill in. All VITE_* vars are exposed to the browser.

# Your Pollar SDK API key (for an app that has SOLANA enabled).
VITE_POLLAR_API_KEY=

# Optional: override the Pollar SDK base URL (default https://sdk.api.pollar.xyz).
# Point at your local sdk-api to test the SIWS endpoints, e.g.
# VITE_POLLAR_BASE_URL=https://sdk.api.local.pollar.xyz
