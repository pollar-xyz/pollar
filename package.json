{
  "name": "polar-auth-monorepo",
  "version": "0.6.2",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:push": "npm run build && cd packages/core && yalc publish && cd ../../packages/react && yalc publish && cd ../../packages/privy-adapter && yalc publish && cd ../../packages/stellar-wallets-kit-adapter && yalc publish",
    "core:publish": "cd packages/core && npm publish --access public",
    "privy-adapter:publish": "cd packages/privy-adapter && npm publish --access public",
    "react:publish": "cd packages/react && npm publish --access public",
    "stellar-wallets-kit-adapter:publish": "cd packages/stellar-wallets-kit-adapter && npm publish --access public",
    "core:update-openapi": "curl -k https://sdk.api.local.pollar.xyz/openapi.json -o /tmp/openapi.json && npx openapi-typescript /tmp/openapi.json -o ./packages/core/src/api/schema.d.ts",
    "test:smoke": "node tests/smoke-keys.cjs && node tests/smoke-client.cjs"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.4"
}
