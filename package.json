{
  "name": "polar-auth-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:push": "npm run build && cd packages/core && yalc publish && cd ../../packages/react && yalc publish",
    "core:publish": "cd packages/core && npm publish --registry https://verdaccio.oscargauss.com/",
    "react:publish": "cd packages/react && npm publish --registry https://verdaccio.oscargauss.com/",
    "core:update-openapi": "curl -k https://sdk.api.local.pollar.xyz/openapi.json -o /tmp/openapi.json && npx openapi-typescript /tmp/openapi.json -o ./packages/core/src/api/schema.d.ts"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@pollar/core": "file:.yalc/@pollar/core",
    "@pollar/react": "file:.yalc/@pollar/react"
  }
}
